---
const docsBase = 'https://dmontgomery40.github.io/ragweld/latest';

const screenshots = [
  {
    title: 'API routing and channel overrides',
    description:
      'Generation and enrichment routing in one surface, with HTTP and MCP channel overrides visible in the same control plane.',
    src: '/screenshots/routing-api-mcp.png',
    href: `${docsBase}/api/`,
    hrefLabel: 'Open API docs',
    alt: 'RAG retrieval generation panel with API and MCP model override controls.',
  },
  {
    title: 'Indexing guardrails in production mode',
    description:
      'Embedding mismatch detection, index contract lock controls, and guided reindex actions reduce high-cost indexing errors.',
    src: '/screenshots/indexing-guardrails.png',
    href: `${docsBase}/manual/indexing/`,
    hrefLabel: 'Open indexing guide',
    alt: 'Code indexing panel with embedding mismatch alerts and model controls.',
  },
  {
    title: 'Learning Agent Studio',
    description:
      'Train and promote adapters with visual telemetry, synthetic dataset hooks, and run inspection in one workspace.',
    src: '/screenshots/learning-agent-studio.png',
    href: `${docsBase}/reference/config/training/`,
    hrefLabel: 'Open training config docs',
    alt: 'Learning Agent Studio with neural visualizer and inspector panel.',
  },
  {
    title: 'Live training visualizer',
    description:
      'Follow gradient-descent motion and run-state telemetry in real time while training is in progress.',
    src: '/screenshots/learning-agent-visualizer.png',
    href: `${docsBase}/howto/reranker/`,
    hrefLabel: 'Open reranker training guide',
    alt: 'Live learning visualizer with gradient telemetry and run controls.',
  },
  {
    title: 'Graph explorer and entity inspection',
    description:
      'Graph retrieval is inspectable directly in-product, with entity lists and neighborhood visualization for corpus debugging.',
    src: '/screenshots/graph-explorer.png',
    href: `${docsBase}/retrieval/overview/`,
    hrefLabel: 'Open retrieval docs',
    alt: 'Graph explorer view with entity table and relationship graph.',
  },
  {
    title: 'Recall gating controls',
    description:
      'Control how conversational memory is indexed and injected with intensity, recency, and skip-behavior gates.',
    src: '/screenshots/recall-gating.png',
    href: `${docsBase}/reference/config/chat/`,
    hrefLabel: 'Open chat config docs',
    alt: 'Chat recall settings panel with retrieval gate controls and tooltip.',
  },
  {
    title: 'Chat + dataset iteration loop',
    description:
      'Ask grounded questions, inspect sources, and keep dataset/eval context close while iterating in the same flow.',
    src: '/screenshots/chat-and-dataset.png',
    href: `${docsBase}/manual/search/`,
    hrefLabel: 'Open search manual',
    alt: 'Chat view shown alongside dataset context and source references.',
  },
];
---

<section id="screenshots" class="bg-[#09090b] pb-20">
  <div class="mx-auto max-w-7xl px-4">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-white">Workbench snapshots</h2>
      <p class="mt-3 text-gray-400">
        Current production surfaces across API routing, indexing, training, graph inspection, and recall policy.
      </p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        screenshots.map(({ title, description, src, alt, href, hrefLabel }) => (
          <figure class="overflow-hidden rounded-xl border border-[#27272a] bg-[#0f0f12]">
            <a href={src} target="_blank" rel="noopener" class="block">
              <img
                src={src}
                alt={alt}
                loading="lazy"
                decoding="async"
                class="h-56 w-full border-b border-[#27272a] object-cover object-left-top"
              />
            </a>
            <figcaption class="p-6">
              <div class="text-sm font-semibold text-[#64748b]">{title}</div>
              <p class="mt-2 text-sm text-gray-400">{description}</p>
              <div class="mt-4 flex items-center justify-between gap-2">
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center rounded-md border border-[#334155] bg-[#111827] px-3 py-1.5 text-xs font-semibold text-[#cbd5e1] hover:border-[#64748b] hover:text-white transition-colors"
                >
                  {hrefLabel}
                </a>
                <span class="text-xs text-gray-500">Click image to enlarge</span>
              </div>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
