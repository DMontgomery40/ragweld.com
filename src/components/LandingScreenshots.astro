---
const docsBase = 'https://dmontgomery40.github.io/ragweld/latest';

const screenshots = [
  {
    title: 'API routing control plane',
    description:
      'Route model traffic per channel with API-first defaults, MCP overrides, and provider readiness visible in one place.',
    src: '/screenshots/routing-api-mcp.png',
    href: `${docsBase}/api/`,
    hrefLabel: 'API docs',
    alt: 'RAG routing panel with API-first model routing and MCP override controls.',
  },
  {
    title: 'Indexing guardrails in production mode',
    description:
      'Embedding mismatch detection, index contract lock controls, and guided reindex actions reduce high-cost indexing errors.',
    src: '/screenshots/indexing-guardrails.png',
    href: `${docsBase}/manual/indexing/`,
    hrefLabel: 'Indexing manual',
    alt: 'Code indexing panel with embedding mismatch alerts and model controls.',
  },
  {
    title: 'Learning Agent Studio run HUD',
    description:
      'Track completed and failed runs side-by-side with run status, duration, active model path, and promotion controls.',
    src: '/screenshots/learning-agent-run-hud.png',
    href: `${docsBase}/reference/config/training/`,
    hrefLabel: 'Training reference',
    alt: 'Learning Agent Studio showing run HUD status panel, run timeline, and training controls.',
  },
  {
    title: 'Recall gating controls',
    description:
      'Control how conversational memory is indexed and injected with intensity, recency, and skip-behavior gates.',
    src: '/screenshots/recall-gating.png',
    href: `${docsBase}/reference/config/chat/`,
    hrefLabel: 'Chat config docs',
    alt: 'Chat recall settings panel with retrieval gate controls and intensity options.',
  },
  {
    title: 'Knowledge graph canvas',
    description:
      'Inspect neighborhood structure directly to validate entity relationships and graph-retrieval behavior.',
    src: '/screenshots/knowledge-graph-canvas.png',
    href: `${docsBase}/retrieval/graph/`,
    hrefLabel: 'Graph retrieval docs',
    alt: 'Knowledge graph canvas showing entities and connections for retrieval debugging.',
  },
  {
    title: 'Dock chooser for custom layouts',
    description:
      'Recompose the workspace quickly by docking the exact tabs and diagnostics needed for the current investigation.',
    src: '/screenshots/dock-chooser.png',
    href: `${docsBase}/manual/ui/`,
    hrefLabel: 'UI manual',
    alt: 'Dock chooser modal listing workspace tabs for custom layout composition.',
  },
];
---

<section id="screenshots" class="bg-[#09090b] pb-20">
  <div class="mx-auto max-w-7xl px-4">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-white">Workbench snapshots</h2>
      <p class="mt-3 text-gray-400">
        Current production surfaces across API routing, indexing, training, graph inspection, and recall policy.
      </p>
    </div>

    <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        screenshots.map(({ title, description, src, alt, href, hrefLabel }) => (
          <figure class="overflow-hidden rounded-xl border border-[#27272a] bg-[#0f0f12]">
            <a href={src} target="_blank" rel="noopener" class="block">
              <img
                src={src}
                alt={alt}
                loading="lazy"
                decoding="async"
                class="h-56 w-full border-b border-[#27272a] object-cover object-left-top"
              />
            </a>
            <figcaption class="p-6">
              <div class="text-sm font-semibold text-[#64748b]">{title}</div>
              <p class="mt-2 text-sm text-gray-400">{description}</p>
              <div class="mt-4 flex items-center justify-between gap-2">
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center rounded-md border border-[#334155] bg-[#111827] px-3 py-1.5 text-xs font-semibold text-[#cbd5e1] hover:border-[#64748b] hover:text-white transition-colors"
                >
                  {hrefLabel}
                </a>
                <span class="text-xs text-gray-500">Click image to enlarge</span>
              </div>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
