---
const docsBase = 'https://dmontgomery40.github.io/ragweld/latest';

const gallery = [
  {
    title: 'Learning visualizer with run HUD',
    description:
      'Live gradient-descent trajectory and run telemetry stay visible while you tune training settings and promotion thresholds.',
    src: '/screenshots/learning-agent-visualizer.png',
    href: `${docsBase}/reference/config/training/`,
    hrefLabel: 'Training reference',
    alt: 'Live training visualizer with run metrics and inspector controls.',
  },
  {
    title: 'Recall gates and memory intensity control',
    description:
      'Decide when recall memory should inject context, with skip rules and intensity defaults that prevent over-injection.',
    src: '/screenshots/recall-gating.png',
    href: `${docsBase}/reference/config/chat/`,
    hrefLabel: 'Chat config',
    alt: 'Recall settings with smart gating, intensity, and recency controls.',
  },
  {
    title: 'Infrastructure services panel',
    description:
      'Postgres, Neo4j, Prometheus, and runtime controls are accessible directly in the operator surface.',
    src: '/screenshots/infrastructure-services.png',
    href: `${docsBase}/operations/`,
    hrefLabel: 'Operations docs',
    alt: 'Infrastructure services dashboard with runtime and container controls.',
  },
  {
    title: 'Knowledge graph canvas',
    description:
      'Entity neighborhoods and relationship structure can be inspected directly during retrieval debugging.',
    src: '/screenshots/knowledge-graph-canvas.png',
    href: `${docsBase}/retrieval/graph/`,
    hrefLabel: 'Graph retrieval docs',
    alt: 'Knowledge graph canvas with linked entities and relationship legend.',
  },
  {
    title: 'Dock chooser for custom operator layouts',
    description:
      'Recompose the workspace quickly by docking the exact tabs and diagnostics you need for the current investigation.',
    src: '/screenshots/dock-chooser.png',
    href: `${docsBase}/manual/ui/`,
    hrefLabel: 'UI manual',
    alt: 'Dock chooser modal listing workspace tabs for custom layout composition.',
  },
  {
    title: 'Chat plus dataset/eval iteration loop',
    description:
      'Run grounded chat while keeping dataset and evidence context close for rapid eval iteration.',
    src: '/screenshots/chat-and-dataset.png',
    href: `${docsBase}/manual/search/`,
    hrefLabel: 'Search manual',
    alt: 'Chat panel shown with dataset and evidence context nearby.',
  },
];
---

<section id="screenshots" class="bg-[#09090b] pb-24">
  <div class="mx-auto max-w-7xl px-4">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="text-3xl font-bold text-white">Operational snapshots</h2>
      <p class="mt-3 text-gray-400">
        Current workbench surfaces across training, retrieval, memory policy, and infra operations.
      </p>
    </div>

    <div class="mt-10 flex snap-x snap-mandatory gap-6 overflow-x-auto pb-4 [scrollbar-width:thin]">
      {
        gallery.map(({ title, description, src, alt, href, hrefLabel }) => (
          <figure class="group min-w-[88vw] snap-start overflow-hidden rounded-2xl border border-[#242833] bg-[#0f1118] md:min-w-[720px] lg:min-w-[820px]">
            <a href={src} target="_blank" rel="noopener" class="block">
              <img
                src={src}
                alt={alt}
                loading="lazy"
                decoding="async"
                class="h-[320px] w-full border-b border-[#242833] object-cover object-left-top transition duration-500 group-hover:scale-[1.015] md:h-[430px]"
              />
            </a>
            <figcaption class="space-y-3 p-6">
              <div class="text-lg font-semibold text-white">{title}</div>
              <p class="text-sm leading-relaxed text-gray-400">{description}</p>
              <div class="flex items-center justify-between gap-2">
                <a
                  href={href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center rounded-md border border-[#334155] bg-[#111827] px-3 py-1.5 text-xs font-semibold text-[#cbd5e1] hover:border-[#64748b] hover:text-white transition-colors"
                >
                  {hrefLabel}
                </a>
                <span class="text-xs text-gray-500">Scroll for more screenshots</span>
              </div>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
