---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Offerings from '../components/Offerings.astro';
import LandingScreenshots from '../components/LandingScreenshots.astro';
import CapabilityPanels from '../components/CapabilityPanels.astro';
import CTA from '../components/CTA.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="ragweld — Open-source MLOps Engineering Platform"
  description="ragweld is an open-source MLOps Engineering Platform for retrieval and agent systems: API-first orchestration, synthetic data lab, dual training studios, eval drilldowns, tracing, observability, and MCP integration."
  canonical="https://ragweld.com/"
  ogImage="/og-image.png"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "ragweld",
      "description": "Open-source MLOps Engineering Platform with API-first retrieval orchestration, synthetic data generation, training studios, eval drilldowns, tracing, and MCP integration.",
      "url": "https://ragweld.com",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Linux, macOS, Windows (Docker)",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD",
        "description": "Free self-hosted (MIT license)"
      },
      "author": {
        "@type": "Person",
        "name": "David Montgomery",
        "url": "https://github.com/DMontgomery40"
      },
      "codeRepository": "https://github.com/DMontgomery40/ragweld",
      "license": "https://opensource.org/licenses/MIT"
    })} />
  </Fragment>
  <Nav />
  <main>
    <Hero />
    <section id="what" class="bg-[#09090b] pb-16">
      <div class="mx-auto max-w-7xl px-4">
        <div class="mx-auto max-w-4xl text-center">
          <h2 class="text-3xl font-bold text-white">What ragweld is now</h2>
          <p class="mt-3 text-gray-400">
            A full MLOps engineering platform for retrieval + agent systems. The product center is API-first orchestration
            for indexing, retrieval, evals, training, tracing, and routing.
          </p>
          <p class="mt-3 text-gray-500">
            MCP support is first-class, but it sits on top of the API contract rather than replacing it. The panels below
            map core workflows to their matching docs destinations.
          </p>
          <div class="mt-6 flex flex-wrap items-center justify-center gap-3">
            <a
              href="https://dmontgomery40.github.io/ragweld/latest/api/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-[#334155] bg-[#111827] px-5 py-2.5 text-sm font-semibold text-[#cbd5e1] hover:border-[#64748b] hover:text-white transition-colors"
            >
              API docs first →
            </a>
            <a
              href="https://dmontgomery40.github.io/ragweld/latest/integrations/mcp/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg border border-[#27272a] px-5 py-2.5 text-sm font-semibold text-white hover:bg-[#18181b] transition-colors"
            >
              MCP integration docs →
            </a>
            <a
              href="/glossary"
              class="inline-flex items-center gap-2 rounded-lg border border-[#27272a] px-5 py-2.5 text-sm font-semibold text-white hover:bg-[#18181b] transition-colors"
            >
              Parameter glossary →
            </a>
          </div>
        </div>

        <CapabilityPanels />
      </div>
    </section>

    <LandingScreenshots />
    <section id="how" class="bg-[#09090b] pb-20">
      <div class="mx-auto max-w-7xl px-4">
        <div class="mx-auto max-w-3xl text-center">
          <h2 class="text-3xl font-bold text-white">Under the hood</h2>
          <p class="mt-3 text-gray-400">
            Three-leg retrieval is the spine: vector + sparse + graph signals fused and reranked — then surfaced through a
            workbench that lets you measure and iterate.
          </p>
        </div>
        <div class="mt-10 space-y-6">
          <article class="rounded-2xl border border-[#232732] bg-[#0f1118] p-6 md:p-8">
            <div class="grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
              <div>
                <h3 class="text-xl font-semibold text-white">Tri-brid retrieval engine</h3>
                <p class="mt-3 text-sm leading-relaxed text-gray-400">
                  Index once, then retrieve through vector, sparse, and graph legs in parallel. Fusion and reranking happen with
                  inspectable knobs so changes are measurable instead of opaque.
                </p>
              </div>
              <div class="grid gap-3 text-sm text-gray-300">
                <div class="rounded-lg border border-[#2a2f3d] bg-[#0b0d13] px-4 py-3">Vector + sparse + graph retrieval orchestration</div>
                <div class="rounded-lg border border-[#2a2f3d] bg-[#0b0d13] px-4 py-3">Learning reranker and agent studio in the same loop</div>
                <div class="rounded-lg border border-[#2a2f3d] bg-[#0b0d13] px-4 py-3">Per-run inspection with configurable promotion gates</div>
              </div>
            </div>
          </article>

          <article class="rounded-2xl border border-[#232732] bg-[#0f1118] p-6 md:p-8">
            <div class="grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
              <div>
                <h3 class="text-xl font-semibold text-white">MLOps iteration loop</h3>
                <p class="mt-3 text-sm leading-relaxed text-gray-400">
                  The workbench is built for repeated cycles: synthetic data generation, eval runs, tracing, and routing updates
                  all feed the same decision surface. API routes stay primary; MCP rides on top for agent clients.
                </p>
              </div>
              <div class="grid gap-3 text-sm text-gray-300">
                <div class="rounded-lg border border-[#2a2f3d] bg-[#0b0d13] px-4 py-3">Synthetic data recipes + eval dataset workflows</div>
                <div class="rounded-lg border border-[#2a2f3d] bg-[#0b0d13] px-4 py-3">Tracing + Grafana support for live diagnostics</div>
                <div class="rounded-lg border border-[#2a2f3d] bg-[#0b0d13] px-4 py-3">Semantic cache and recall gates for token efficiency</div>
              </div>
            </div>
          </article>
        </div>
      </div>
    </section>

    <Offerings />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
