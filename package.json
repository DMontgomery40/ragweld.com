{
  "name": "ragweld.com",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "sync:demo": "node scripts/sync-demo.cjs --source ../ragweld/web",
    "check:demo-parity": "node scripts/check-demo-parity.cjs --source ../ragweld/web",
    "fix:demo-parity": "node scripts/check-demo-parity.cjs --source ../ragweld/web --fix",
    "deps:demo": "(npm --prefix vendor/demo ci || npm --prefix vendor/demo install) && node scripts/ensure-demo-msw.cjs",
    "build:demo": "VITE_BUILD_BASE=/demo/ VITE_ROUTER_BASENAME=/demo VITE_DEMO_MSW_MODE=partial npm --prefix vendor/demo run build",
    "build": "npm run deps:demo && npm run build:demo && astro build && node scripts/copy-demo.cjs",
    "test:e2e": "playwright test",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/tailwind": "^6.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@netlify/neon": "^0.1.2",
    "astro": "^5.1.0",
    "deepseek-mcp-server": "https://codeload.github.com/DMontgomery40/deepseek-mcp-server/tar.gz/a0cf6c46427397f5df69708c437c2db6023a2a92",
    "neo4j-driver": "^5.28.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@netlify/functions": "^2.8.0",
    "@playwright/test": "^1.54.0",
    "@tailwindcss/typography": "^0.5.16",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "pg": "^8.11.5",
    "tailwindcss": "^3.4.0"
  }
}
